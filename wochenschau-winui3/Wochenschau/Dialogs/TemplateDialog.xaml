<ContentDialog
    x:Class="Wochenschau.Dialogs.TemplateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonText="Speichern"
    CloseButtonText="Abbrechen"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind IsSaveEnabled, Mode=OneWay}">

    <StackPanel Spacing="12" Width="300">

        <StackPanel Spacing="4">
            <TextBlock Text="Name *" FontWeight="SemiBold" />
            <TextBox x:Name="NameBox"
                     PlaceholderText="z. B. Morgenrunde"
                     TextChanged="Validate" />
        </StackPanel>

        <Grid ColumnDefinitions="*,Auto,*">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Von" FontWeight="SemiBold" />
                <TextBox x:Name="StartTimeBox"
                         PlaceholderText="08:00"
                         TextChanged="Validate" />
            </StackPanel>
            <TextBlock Grid.Column="1" Text="–"
                       VerticalAlignment="Bottom" Margin="8,0,8,8" />
            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="Bis" FontWeight="SemiBold" />
                <TextBox x:Name="EndTimeBox"
                         PlaceholderText="09:00"
                         TextChanged="Validate" />
            </StackPanel>
        </Grid>

        <StackPanel Spacing="4">
            <TextBlock Text="Beschreibung" FontWeight="SemiBold" />
            <TextBox x:Name="DescriptionBox"
                     PlaceholderText="Optional"
                     Height="60"
                     AcceptsReturn="True"
                     TextWrapping="Wrap" />
        </StackPanel>

    </StackPanel>
</ContentDialog>
