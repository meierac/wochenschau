<Page
    x:Class="Wochenschau.Views.WeekPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Wochenschau.Views"
    xmlns:vm="using:Wochenschau.ViewModels"
    xmlns:models="using:Wochenschau.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Toolbar ── -->
        <Grid Grid.Row="0" Padding="12,8" ColumnDefinitions="Auto,*,Auto,Auto,Auto">
            <Button Grid.Column="0"
                    Content="&#xE760;"
                    FontFamily="Segoe MDL2 Assets"
                    ToolTipService.ToolTip="Vorherige Woche"
                    Command="{x:Bind ViewModel.PreviousWeekCommand}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="KW" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.CurrentWeek, Mode=OneWay}"
                           FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text=" / " FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.CurrentYear, Mode=OneWay}"
                           FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="2"
                    Content="Heute"
                    Margin="4,0"
                    Command="{x:Bind ViewModel.GoToTodayCommand}" />

            <Button Grid.Column="3"
                    Content="&#xE72A;"
                    FontFamily="Segoe MDL2 Assets"
                    Margin="4,0"
                    ToolTipService.ToolTip="Kalender aktualisieren"
                    IsEnabled="{x:Bind ViewModel.IsRefreshing, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                    Command="{x:Bind ViewModel.RefreshSubscriptionsCommand}" />

            <Button Grid.Column="4"
                    Content="&#xE710;"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{ThemeResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Aktivität hinzufügen"
                    Click="AddActivityButton_Click" />
        </Grid>

        <!-- ── Status bar ── -->
        <Border Grid.Row="1"
                Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                Padding="12,4"
                Visibility="{x:Bind ViewModel.IsRefreshing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ProgressRing Width="16" Height="16" IsActive="{x:Bind ViewModel.IsRefreshing, Mode=OneWay}" />
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ── Weekly Grid ── -->
        <ScrollViewer Grid.Row="2" HorizontalScrollMode="Enabled"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="WeekGrid"
                          ItemsSource="{x:Bind ViewModel.DayColumns, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DayColumn">
                        <!-- Day column -->
                        <Border Width="180" Margin="4,0"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8">
                            <Grid RowDefinitions="Auto,*">
                                <!-- Day header -->
                                <Border Grid.Row="0"
                                        Background="{ThemeResource SystemFillColorSolidAttentionBackgroundBrush}"
                                        CornerRadius="8,8,0,0"
                                        Padding="8,6">
                                    <TextBlock Text="{x:Bind Header}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!-- Activities list -->
                                <ItemsControl Grid.Row="1" ItemsSource="{x:Bind Items}"
                                              Padding="6,6" MinHeight="80">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:CalendarItem">
                                            <Border Margin="0,3" Padding="8,6"
                                                    CornerRadius="6"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    Tag="{x:Bind}"
                                                    PointerPressed="ActivityCard_PointerPressed">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{x:Bind Summary}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"
                                                               TextWrapping="WrapWholeWords"
                                                               MaxLines="2" />
                                                    <TextBlock Text="{x:Bind TimeLabel}"
                                                               FontSize="11"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Text="{x:Bind Description}"
                                                               FontSize="11"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               TextWrapping="WrapWholeWords"
                                                               MaxLines="3"
                                                               Visibility="{x:Bind Description, Converter={StaticResource StringToVisibilityConverter}}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>

    <Page.Resources>
        <local:BoolNegationConverter x:Key="BoolNegationConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>
</Page>
